# === Core ===
BOT_TOKEN=
USE_WEBHOOK=true
WEBHOOK_BASE_URL=
WEBHOOK_PATH=/webhook
PORT=8000
WEBHOOK_SECRET=

# === Database (PostgreSQL) ===
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/lumi
DB_POOL_MIN=2
DB_POOL_MAX=10

# === NVIDIA NIM (Kimi-K2-Thinking) ===
NVIDIA_API_KEY=
NVIDIA_MODEL=moonshotai/kimi-k2-thinking
NVIDIA_BASE_URL=https://integrate.api.nvidia.com/v1
NVIDIA_MAX_TOKENS=16384
NVIDIA_TEMPERATURE=0.6
NVIDIA_TIMEOUT=300

# === Whisper (STT) — can use NVIDIA NIM or any OpenAI-compatible endpoint ===
WHISPER_API_KEY=
WHISPER_MODEL=whisper-1
WHISPER_BASE_URL=

# === Vision — can use NVIDIA NIM or any OpenAI-compatible endpoint ===
VISION_API_KEY=
VISION_MODEL=gpt-4o
VISION_BASE_URL=

# === Tavily Search ===
TAVILY_API_KEY=
TAVILY_MAX_RESULTS=5
TAVILY_SEARCH_DEPTH=advanced
TAVILY_INCLUDE_RAW=false
TAVILY_TIMEOUT=30

# === Memory & Dialog ===
MAX_DIALOG_MESSAGES=50
SHORT_TERM_TTL_HOURS=24
LONG_TERM_MAX_FACTS=100

# === General ===
LOG_LEVEL=INFO
RATE_LIMIT_SECONDS=1.0
ADMIN_IDS=